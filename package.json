{
  "name": "video-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Automated video generation and publishing factory",
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "echo '请分别在两个终端运行: npm run dev 和 npm run worker:dev'",
    "dev:web": "turbo dev --filter @video-factory/web",
    "dev:desktop": "turbo dev --filter @video-factory/desktop",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "web": "pnpm --filter @video-factory/web",
    "desktop": "pnpm --filter @video-factory/desktop",
    "worker": "pnpm --filter @video-factory/worker",
    "database": "pnpm --filter @video-factory/database",
    "worker:dev": "cd apps/worker && uv run uvicorn src.main:app --host 0.0.0.0 --port 8000 --reload",
    "worker:sync": "cd apps/worker && uv sync",
    "worker:test": "cd apps/worker && python -m pytest --cov=src --cov-report=term-missing --timeout=30",
    "test": "turbo test && npm run worker:test",
    "coverage": "turbo test:coverage && npm run worker:test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
