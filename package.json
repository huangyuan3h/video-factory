{
  "name": "video-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Automated video generation and publishing factory",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "web": "pnpm --filter @video-factory/web",
    "desktop": "pnpm --filter @video-factory/desktop",
    "worker": "pnpm --filter @video-factory/worker",
    "database": "pnpm --filter @video-factory/database"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}